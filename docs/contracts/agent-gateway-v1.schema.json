{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://leanctx.dev/contracts/agent-gateway-v1.schema.json",
  "title": "OCLA Agent Gateway Contract v1",
  "description": "Schema for P11 Agent Gateway relay admission, capsule manifests, work graph, chain compression, and attribution.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/ContextCapsuleV1" },
    { "$ref": "#/$defs/AgentEnvelopeV1" },
    { "$ref": "#/$defs/AgentLeaseRequestV1" },
    { "$ref": "#/$defs/WorkNodeV1" },
    { "$ref": "#/$defs/ChainDeltaV1" },
    { "$ref": "#/$defs/ChainAttributionV1" },
    { "$ref": "#/$defs/DeploymentProfileV1" }
  ],
  "$defs": {
    "ContextCapsuleV1": {
      "type": "object",
      "required": ["schema_version", "capsule_id", "request_id", "session_id", "agent_id", "intent_ref", "task_ref", "expected_outcome_ref", "source_ref", "policy_ref", "contract_ref", "freshness_ref", "sensitivity", "allowed_agent_ids", "budget", "chain"],
      "properties": {
        "schema_version": { "type": "integer", "const": 1 },
        "capsule_id": { "type": "string", "pattern": "^capsule:[a-f0-9]{64}$" },
        "request_id": { "type": "string" },
        "session_id": { "type": "string" },
        "agent_id": { "type": "string", "minLength": 1, "maxLength": 256 },
        "intent_ref": { "type": "string" },
        "task_ref": { "type": "string" },
        "expected_outcome_ref": { "type": "string" },
        "sensitivity": { "type": "string", "enum": ["public", "internal", "restricted"] },
        "allowed_agent_ids": { "type": "array", "items": { "type": "string" }, "minItems": 1, "maxItems": 64 },
        "budget": { "$ref": "#/$defs/CapsuleBudget" },
        "chain": { "$ref": "#/$defs/CapsuleChain" },
        "delta_from": { "type": ["string", "null"] }
      }
    },
    "CapsuleBudget": {
      "type": "object",
      "required": ["tokens_used", "tokens_remaining", "cost_micros_used", "cost_micros_remaining"],
      "properties": {
        "tokens_used": { "type": "integer", "minimum": 0 },
        "tokens_remaining": { "type": "integer", "minimum": 0 },
        "cost_micros_used": { "type": "integer", "minimum": 0 },
        "cost_micros_remaining": { "type": "integer", "minimum": 0 },
        "latency_ms_used": { "type": "integer", "minimum": 0 },
        "latency_ms_remaining": { "type": "integer", "minimum": 0 }
      }
    },
    "CapsuleChain": {
      "type": "object",
      "required": ["chain_id", "owner_agent_id", "attribution_ref", "hop"],
      "properties": {
        "chain_id": { "type": "string" },
        "parent_capsule_ref": { "type": ["string", "null"] },
        "owner_agent_id": { "type": "string" },
        "attribution_ref": { "type": "string" },
        "hop": { "type": "integer", "minimum": 0, "maximum": 256 }
      }
    },
    "AgentEnvelopeV1": {
      "type": "object",
      "required": ["schema_version", "relay_id", "from_agent_id", "to_agent_id", "capsule_ref", "budget_tokens"],
      "properties": {
        "schema_version": { "type": "integer", "const": 1 },
        "relay_id": { "type": "string", "pattern": "^agent-relay:" },
        "from_agent_id": { "type": "string", "minLength": 1 },
        "to_agent_id": { "type": "string", "minLength": 1 },
        "capsule_ref": { "type": "string", "pattern": "^capsule:" },
        "budget_tokens": { "type": "integer", "minimum": 1 }
      }
    },
    "AgentLeaseRequestV1": {
      "type": "object",
      "required": ["schema_version", "lease_request_ref", "resource_kind", "resource_ref", "owner_agent_id", "duration_ms"],
      "properties": {
        "schema_version": { "type": "integer", "const": 1 },
        "lease_request_ref": { "type": "string" },
        "resource_kind": { "type": "string", "enum": ["path", "symbol"] },
        "resource_ref": { "type": "string" },
        "owner_agent_id": { "type": "string" },
        "duration_ms": { "type": "integer", "minimum": 1, "maximum": 3600000 }
      }
    },
    "WorkNodeV1": {
      "type": "object",
      "required": ["node_id", "agent_id", "capsule_ref", "status", "budget", "depth"],
      "properties": {
        "node_id": { "type": "string" },
        "agent_id": { "type": "string" },
        "parent_node_id": { "type": ["string", "null"] },
        "capsule_ref": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "active", "completed", "stopped", "failed"] },
        "budget": {
          "type": "object",
          "required": ["tokens_allocated", "tokens_consumed", "cost_micros_allocated", "cost_micros_consumed"],
          "properties": {
            "tokens_allocated": { "type": "integer", "minimum": 0 },
            "tokens_consumed": { "type": "integer", "minimum": 0 },
            "cost_micros_allocated": { "type": "integer", "minimum": 0 },
            "cost_micros_consumed": { "type": "integer", "minimum": 0 }
          }
        },
        "depth": { "type": "integer", "minimum": 0, "maximum": 8 },
        "stop_reason": { "type": ["string", "null"], "enum": ["budget_exhausted", "stale", "redundant", "parent_stopped", "manual_stop", "depth_exceeded", "fan_out_exceeded", null] }
      }
    },
    "ChainDeltaV1": {
      "type": "object",
      "required": ["schema_version", "chain_id", "from_hop", "to_hop", "added_refs", "removed_refs", "unchanged_count", "total_refs_at_target", "compression_ratio"],
      "properties": {
        "schema_version": { "type": "integer", "const": 1 },
        "chain_id": { "type": "string" },
        "from_hop": { "type": "integer", "minimum": 0 },
        "to_hop": { "type": "integer", "minimum": 0 },
        "added_refs": { "type": "array", "items": { "type": "string" } },
        "removed_refs": { "type": "array", "items": { "type": "string" } },
        "unchanged_count": { "type": "integer", "minimum": 0 },
        "total_refs_at_target": { "type": "integer", "minimum": 0 },
        "compression_ratio": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
      }
    },
    "ChainAttributionV1": {
      "type": "object",
      "required": ["schema_version", "chain_id", "outcome_verdict", "total_tokens_all_agents", "effective_tokens_accepted", "waste_tokens"],
      "properties": {
        "schema_version": { "type": "integer", "const": 1 },
        "chain_id": { "type": "string" },
        "outcome_verdict": { "type": "string", "enum": ["pending", "accepted", "rejected", "partial"] },
        "total_tokens_all_agents": { "type": "integer", "minimum": 0 },
        "total_cost_all_agents": { "type": "integer", "minimum": 0 },
        "effective_tokens_accepted": { "type": "integer", "minimum": 0 },
        "effective_cost_accepted": { "type": "integer", "minimum": 0 },
        "waste_tokens": { "type": "integer", "minimum": 0 },
        "waste_cost": { "type": "integer", "minimum": 0 }
      }
    },
    "DeploymentProfileV1": {
      "type": "object",
      "required": ["schema_version", "kind", "display_name", "features", "is_oss", "requires_license", "cli_entry_point"],
      "properties": {
        "schema_version": { "type": "integer", "const": 1 },
        "kind": { "type": "string", "enum": ["org_gateway_base", "team_control_base", "ai_value_gate"] },
        "display_name": { "type": "string" },
        "is_oss": { "type": "boolean" },
        "requires_license": { "type": "boolean" },
        "cli_entry_point": { "type": "string" }
      }
    }
  }
}
